# AI Gateway Configuration
# The first model in AVAILABLE_MODELS is used as default when no selection is made.
AVAILABLE_MODELS=(
  "gpt-4.1"
  "gpt-5-mini"
  "claude-haiku-4.5"
  "claude-sonnet-4.5"
  "claude-sonnet-4.6"
  "claude-opus-4.5"
  "claude-opus-4.6"
  "gemini-3-pro-preview"
)

# Number of retry attempts on failure
MAX_RETRIES=2

# Request timeout in seconds
TIMEOUT=60
